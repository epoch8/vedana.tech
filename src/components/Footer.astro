---
import BrandLogo from './BrandLogo.astro';

const cols = [
  { title: "Product", items: ["Docs","Changelog","Status"] },
  { title: "Use cases", items: ["E-commerce","SaaS","Creators","Support"] },
  { title: "Resources", items: ["Blog","Templates","Community"] },
  { title: "Company", items: ["About","Careers","Contact","Legal"] },
];
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-grid">
    <div class="footer-brand">
      <BrandLogo />
      <p class="footer-tagline">Omni-channel chat for growth and support. Replace this text with your brand line.</p>
      <div class="footer-socials">
        <div class="social-placeholder"></div>
        <div class="social-placeholder"></div>
        <div class="social-placeholder"></div>
      </div>
    </div>
    {cols.map((c) => (
      <div>
        <h4 class="footer-col-title">{c.title}</h4>
        <ul class="footer-col-links">
          {c.items.map((item) => (
            <li><a href="#">{item}</a></li>
          ))}
        </ul>
      </div>
    ))}
  </div>
  <div class="footer-copyright">
    © {year} Epoch8 LLC
  </div>
</footer>

<style>
.site-footer {
  border-top: 1px solid #e2e8f0;
  background: #fff;
}
.footer-grid {
  max-width: 80rem;
  margin: 0 auto;
  padding: 3rem 1rem;
  display: grid;
  gap: 2.5rem;
}
@media (min-width: 768px) {
  .footer-grid {
    grid-template-columns: repeat(5, 1fr);
  }
}
.footer-brand {
  grid-column: span 1;
}
.footer-tagline {
  margin: 0.75rem 0 0;
  font-size: 0.875rem;
  color: #475569;
  max-width: 18rem;
}
.footer-socials {
  margin-top: 1rem;
  display: flex;
  gap: 0.75rem;
}
.social-placeholder {
  height: 2.25rem;
  width: 2.25rem;
  border-radius: 9999px;
  background: #e2e8f0;
}
.footer-col-title {
  font-weight: 600;
  margin: 0;
  color: #0f172a;
}
.footer-col-links {
  margin: 0.75rem 0 0;
  padding: 0;
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  font-size: 0.875rem;
  color: #475569;
}
.footer-col-links a {
  color: inherit;
  text-decoration: none;
}
.footer-col-links a:hover {
  color: #2563eb;
}
.footer-copyright {
  border-top: 1px solid #e2e8f0;
  padding: 1.5rem;
  text-align: center;
  font-size: 0.875rem;
  color: #64748b;
}
</style>
