</section>

<script is:inline>
  const stack = document.getElementById("dynamicStack");

  if (stack) {
    const items = stack.children;
    let index = 0;

    function updateHeight() {
      const itemHeight = items[0].offsetHeight;
      stack.parentElement.style.height = itemHeight + "px";
      return itemHeight;
    }

    let itemHeight = updateHeight();
    window.addEventListener("resize", () => {
      itemHeight = updateHeight();
    });

    setInterval(() => {
      index = (index + 1) % items.length;
      stack.style.transform = `translateY(-${index * itemHeight}px)`;
    }, 2500);
  }
</script>

