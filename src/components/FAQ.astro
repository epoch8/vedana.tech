---
// FAQ.astro

const items = [
  {
    label: 'Do I need code skills?',
    content: 'No. You can build flows with blocks and rules.',
  },
  {
    label: 'Which channels are supported?',
    content: 'Instagram DM, WhatsApp, Facebook Messenger, SMS, email, and more.',
  },
  {
    label: 'Can I connect my shop?',
    content: 'Yes. Shopify and others. You can sync products and orders.',
  },
  {
    label: 'Is there a free plan?',
    content: 'Yes. Start free and upgrade any time.',
  },
];
---
<section id="faq" class="faq-section">
  <div class="faq-inner">
    <h2>FAQ</h2>
    <div class="faq-accordion">
      {items.map((item, index) => (
        <details class="faq-details" name="faq-accordion">
          <summary class="faq-summary">
            {item.label}
            <span class="faq-icon">
              <!-- Using an SVG plus sign that transforms to X on open -->
              <svg viewBox="64 64 896 896" focusable="false" data-icon="plus" width="1em" height="1em" fill="currentColor" aria-hidden="true">
                <path d="M482 152h60q8 0 8 8v704q0 8-8 8h-60q-8 0-8-8V160q0-8 8-8z"></path>
                <path d="M176 474h672q8 0 8 8v60q0 8-8 8H176q-8 0-8-8v-60q0-8 8-8z"></path>
              </svg>
            </span>
          </summary>
          <div class="faq-content">
            <p>{item.content}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-section {
    padding: 5rem 0;
    background: #f8fafc;
  }
  .faq-inner {
    max-width: 48rem;
    margin: 0 auto;
    padding: 0 1rem;
  }
  h2 {
    text-align: center;
    font-weight: 700;
    font-size: 1.875rem;
    margin: 0;
    color: #0f172a;
    font-family: inherit;
  }
  
  .faq-accordion {
    margin-top: 2rem;
    background: #fff;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid #e5e7eb;
  }
  
  .faq-details {
    border-bottom: 1px solid #e5e7eb;
  }
  .faq-details:last-child {
    border-bottom: none;
  }
  
  .faq-summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.25rem;
    font-size: 14px;
    font-family: inherit;
    color: rgba(0, 0, 0, 0.88);
    cursor: pointer;
    background: #fafafa;
    list-style: none; /* Hide default arrow */
    transition: background 0.3s;
  }
  
  .faq-summary::-webkit-details-marker {
    display: none; /* Hide default arrow in Safari */
  }
  
  .faq-summary:hover {
    background: #f0f0f0;
  }
  
  .faq-icon {
    display: inline-flex;
    align-items: center;
    transition: transform 0.2s cubic-bezier(0.645, 0.045, 0.355, 1);
    color: rgba(0, 0, 0, 0.45);
    font-size: 12px;
  }
  
  .faq-details[open] .faq-summary {
    background: #fafafa;
  }
  
  .faq-details[open] .faq-icon {
    transform: rotate(45deg); /* Turn Plus into X */
  }
  
  .faq-content {
    padding: 0 1.25rem 1rem 1.25rem;
    background: #ffffff;
    border-top: 1px solid #f0f0f0;
  }
  
  /* Smoothly display content (note: native details transition is limited, but padding transition works well) */
  .faq-content {
    padding-top: 1rem;
  }
  
  .faq-content p {
    margin: 0;
    color: #475569;
    font-size: 14px;
    font-family: inherit;
    line-height: 1.5714285714285714;
  }
</style>
