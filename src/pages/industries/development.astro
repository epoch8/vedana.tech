---
import "@/styles/vedana/extra-tokens.css";

import InternalLayout from "@/layouts/InternalLayout.astro";
import { SEOBase } from "@content/vedana/seo/seo";
import type { SEOConfig } from "@/lib/seo/types";

import Callout from "@/components/blocks/callout/Callout.astro";

import EntityCardList from "@/components/blocks/entity-card/EntityCardList.astro";
import EntityCard from "@/components/blocks/entity-card/EntityCard.astro";
import EntityCardRichList from "@/components/blocks/entity-card/EntityCardRichList.astro";
import EntityCardRich from "@/components/blocks/entity-card/EntityCardRich.astro";

import Timeline from "@/components/blocks/timeline/Timeline.astro";
import TimelineItem from "@/components/blocks/timeline/TimelineItem.astro";

import Chat from "@/components/blocks/chat/Chat.astro";
import ChatItem from "@/components/blocks/chat/ChatItem.astro";

import ProductDemo from "@/components/products/vedana/product-demo/ProductDemo.tsx";
import { scenarios, cardRegistry } from "@/content/vedana/demo/development"

const bot = {
  name: "Vedana AI assistant",
  bubbleBg: "#eef3ff"
};

const user = {
  name: "User",
  bubbleBg: "#2A5BFF",
  bubbleColor: "#fff"
};


const crumbs = [
  { label: "Industries", href: "/industries" },
  { label: "Development" }
];

const pageSEO: Partial<SEOConfig> = {
  title: "Vedana for Development",
  description:
    "Structured AI platform for Development industry.",
  canonical: "https://vedana.tech/industries/development",
  og: {
    type: "website",
    image: "https://vedana.tech/og-development.png",
    imageAlt: "Vedana for Development"
  }
};
---

<InternalLayout
  baseSEO={SEOBase}
  pageSEO={pageSEO}
  crumbs={crumbs}
>

    <section class="page-hero">
        <div class="page-hero-inner">
            <h1 class="page-hero-title">
                Development industry runs on expertise.<br />
                But <strong>expertise is hard to scale</strong>.
            </h1>

          <p class="page-hero-lead">
                Vedana is an open-core AI platform, that encodes your internal knowledge and operations logic into a <strong>structured knowledge graph</strong> – so AI answers are verified. That scales expertise across teams, services, and regions.
          </p>
        </div>
    </section>

    <section class="section">
        <div class="container flow">
        <h2>
            Vedana saves your team expertise in <strong>AI-ready knowledge graph</strong>
        </h2>
            <Callout style="--callout-bg: hsl(43 20% 88%);">
                <h3>
                    Pre-modeled Development ontology – ready to extend
                </h3>
                <p></p>
                <p>
                    VEDANA comes with a rich understanding of the Development domain: brands, menu items, recipes, ingredients, equipment, supplies, beverages, certifications, service protocols and others.
                </p>
                <p>
                    We extend this model with your internal logic, formats, and documents, so your assistant answers questions in your language – not just industry standards.
                </p>
            </Callout>
<h3>
    Any Domain = <strong>Anchors, Attributes, Links</strong>
</h3>
<p>
    Vedana represents any business domain as a structured graph of <strong>anchors (entities), their attributes (properties), and explicit links (relationships)</strong>. <br/>
    In this HoReCa mini-demo, dishes, ingredients, suppliers, and certifications are typed nodes connected by governed business logic. 
    <br/>
    <strong>This is the foundation of our methodology: structured modeling first, AI reasoning on top.</strong>
</p>


<EntityCardRichList columns={3}>

  <EntityCardRich
    title="Project"
    entityType="project"
    color="var(--entity-project)"
    attributes={[
      { key: "name", value: "Riverside Residential Complex" },
      { key: "location", value: "Hamburg, Germany" },
      { key: "project type", value: "Mixed‑use residential development" },
      { key: "client", value: "UrbanCore Development GmbH" },
      { key: "planned floors", value: "12" }
    ]}
    relations={[
      {
        label: "Requires",
        targets: [
          { title: "investigation: Geotechnical Survey", entityType: "investigation", color: "var(--entity-investigation)" }
        ]
      },
      {
        label: "Governed by",
        targets: [
          { title: "regulation: Eurocode 7 – Geotechnical Design", entityType: "regulation", color: "var(--entity-regulation)" }
        ]
      }
    ]}
  />

  <EntityCardRich
    title="Technical Assignment"
    entityType="assignment"
    color="var(--entity-assignment)"
    attributes={[
      { key: "document type", value: "Engineering Investigation Scope" },
      { key: "issued by", value: "UrbanCore Development GmbH" },
      { key: "project phase", value: "Pre‑design investigation" },
      { key: "site area", value: "1.8 ha" },
      { key: "document id", value: "TA‑2025‑0142" }
    ]}
    relations={[
      {
        label: "Defines",
        targets: [
          { title: "investigation: Geotechnical Survey", entityType: "investigation", color: "var(--entity-investigation)" }
        ]
      },
      {
        label: "References",
        targets: [
          { title: "regulation: Eurocode 7 – Geotechnical Design", entityType: "regulation", color: "var(--entity-regulation)" }
        ]
      }
    ]}
  />

  <EntityCardRich
    title="Regulation"
    entityType="regulation"
    color="var(--entity-regulation)"
    attributes={[
      { key: "name", value: "Eurocode 7 – Geotechnical Design" },
      { key: "standard code", value: "EN 1997‑1:2004" },
      { key: "domain", value: "Geotechnical engineering" },
      { key: "issuing body", value: "European Committee for Standardization" },
      { key: "applies to", value: "Foundations and soil investigation" }
    ]}
    relations={[
      {
        label: "Defines",
        targets: [
          { title: "investigation: Soil Drilling", entityType: "investigation", color: "var(--entity-investigation)" }
        ]
      }
    ]}
  />

  <EntityCardRich
    title="Investigation"
    entityType="investigation"
    color="var(--entity-investigation)"
    attributes={[
      { key: "name", value: "Geotechnical Survey" },
      { key: "category", value: "Subsurface investigation" },
      { key: "typical methods", value: "Drilling, sampling, lab testing" },
      { key: "required depth", value: "Up to 25 m" },
      { key: "output", value: "Engineering Geological Report" }
    ]}
    relations={[
      {
        label: "Priced by",
        targets: [
          { title: "cost rule: Borehole Drilling Pricing", entityType: "costrule", color: "var(--entity-cost)" }
        ]
      }
    ]}
  />

  <EntityCardRich
    title="Cost Rule"
    entityType="costrule"
    color="var(--entity-cost)"
    attributes={[
      { key: "name", value: "Borehole Drilling Pricing" },
      { key: "price unit", value: "€/meter" },
      { key: "complexity category", value: "Category II soil conditions" },
      { key: "base rate", value: "€120 / m" },
      { key: "source", value: "National Construction Price Book" }
    ]}
    relations={[
      {
        label: "Applies to",
        targets: [
          { title: "investigation: Soil Drilling", entityType: "investigation", color: "var(--entity-investigation)" }
        ]
      }
    ]}
  />

  <EntityCardRich
    title="Work Program"
    entityType="program"
    color="var(--entity-program)"
    attributes={[
      { key: "name", value: "Geotechnical Investigation Program" },
      { key: "prepared for", value: "Riverside Residential Complex" },
      { key: "document type", value: "Engineering investigation plan" },
      { key: "estimated duration", value: "18 days" },
      { key: "report format", value: "EN‑compliant engineering report" }
    ]}
    relations={[
      {
        label: "Includes",
        targets: [
          { title: "investigation: Geotechnical Survey", entityType: "investigation", color: "var(--entity-investigation)" }
        ]
      },
      {
        label: "Complies with",
        targets: [
          { title: "regulation: Eurocode 7 – Geotechnical Design", entityType: "regulation", color: "var(--entity-regulation)" }
        ]
      }
    ]}
  />

</EntityCardRichList>


        </div>
    </section>

    <section class="section">
        <div class="container flow">
        <h2>
            VEDANA makes all your knowledge accessible.
        </h2>
        <h3>
            See how Vedana helps in Development scenarios
        </h3>

          <div class="container">
            <ProductDemo
              scenarios={scenarios}
              cardRegistry={cardRegistry}
              client:load
            />
          </div>

    <section class="section">
        <div class="container flow">
        <h2>
            How Vedana turns documents into answers 
        </h2>
        <p></p>
        <Timeline orientation="horizontal" lines={true}>
            <TimelineItem index="1" title="Normalize data">
                        <p>
                        Pull data from messy pdfs, make data-model. A service-specific playbook guides Vedana how to think:<br/>
                        
                        “If query includes certification + menu item + ingredient → look for menu compatibility across all three entities.”
                        <br />
                        Logic is visible and customizable.
                        </p>
                        </TimelineItem> 
                        <TimelineItem index="2" title="Make a playbook">
                        <p>
                        Vedana explores your knowledge graph:Menu Item → Recipe → Ingredient → Health & Safety Standardto trace dependencies and rules across layers.
                        </p>
                        </TimelineItem> 
                        <TimelineItem index="3" title="Reason using the playbook">
                        <p>
                        Each answer is supported by your data: service specifications, health & safety regulations, menu compatibility logic — not hallucination.Feedback from users is logged and used to improve the Playbook.
                        </p>
                </Timeline>  
        </div>
    </section>
    



    <section class="section">
        <div class="container flow">
        <h2>
            Page header H2-3
        </h1>

        <p>
            Simple page text.
        </p>
        </div>
    </section>


</InternalLayout>