---
import ProcessDiagram from './ProcessDiagram.astro';
---

<section id="home" class="hero-section">
  <div class="hero-bg-gradient"></div>
  <div class="hero-inner">
    <div class="hero-copy">
      <div class="hero-badge">
        <span class="hero-badge-dot"></span>
        Vedana: AI assistants that reason
      </div>
      <h1>Stop guessing. Start understanding.</h1>
      <p class="hero-lead">
        Most AI tools make up facts or skip key details. Vedana uses Semantic RAG — a clear data model of your domain (entities, links, rules) — so answers are grounded and explained.
      </p>
      <ul class="hero-bullets">
        <li><span class="bullet-dot"></span> Fewer made-up answers</li>
        <li><span class="bullet-dot"></span> Cites sources and logic</li>
        <li><span class="bullet-dot"></span> Works with your stack</li>
      </ul>
      <div class="hero-ctas">
        <a href="#demo" class="btn-primary">Try the Demo</a>
        <a href="#contact" class="btn-dark">Talk to Us</a>
      </div>
      <p class="hero-note">Live dataset · No email needed</p>
    </div>
    <div class="hero-diagram">
      <div class="diagram-glow"></div>
      <ProcessDiagram />
    </div>
  </div>
</section>

<style>
.hero-section {
  position: relative;
  overflow: hidden;
}
.hero-bg-gradient {
  pointer-events: none;
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at top, #eff6ff 0%, transparent 60%);
}
.hero-inner {
  position: relative;
  max-width: 80rem;
  margin: 0 auto;
  padding: 5rem 1rem;
  display: grid;
  gap: 2.5rem;
  align-items: center;
}
@media (min-width: 768px) {
  .hero-inner {
    grid-template-columns: 1fr 1fr;
    padding: 7rem 1rem;
  }
}
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  border-radius: 9999px;
  border: 1px solid #e2e8f0;
  background: #fff;
  padding: 0.25rem 0.75rem;
  font-size: 0.75rem;
  color: #475569;
  box-shadow: 0 1px 2px rgba(0,0,0,0.05);
}
.hero-badge-dot {
  display: inline-block;
  height: 0.5rem;
  width: 0.5rem;
  border-radius: 9999px;
  background: #22c55e;
}
h1 {
  margin: 1.25rem 0 0;
  font-size: 2.25rem;
  font-weight: 700;
  letter-spacing: -0.025em;
  color: #0f172a;
  line-height: 1.2;
}
@media (min-width: 768px) {
  h1 { font-size: 3rem; }
}
.hero-lead {
  margin: 1rem 0 0;
  font-size: 1.125rem;
  color: #475569;
  line-height: 1.625;
}
.hero-bullets {
  margin: 1.5rem 0 0;
  padding: 0;
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.hero-bullets li {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.875rem;
  color: #334155;
}
.bullet-dot {
  display: inline-block;
  height: 1rem;
  width: 1rem;
  border-radius: 9999px;
  background: #22c55e;
  flex-shrink: 0;
}
.hero-ctas {
  margin-top: 2rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
@media (min-width: 640px) {
  .hero-ctas {
    flex-direction: row;
    align-items: center;
  }
}
.hero-note {
  margin: 0.5rem 0 0;
  font-size: 0.875rem;
  color: #64748b;
}
.hero-diagram {
  position: relative;
}
.diagram-glow {
  position: absolute;
  inset: -1.5rem;
  background: linear-gradient(to bottom right, #dbeafe, #e0e7ff);
  filter: blur(2.5rem);
  border-radius: 1.5rem;
}
</style>
