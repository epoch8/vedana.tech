---
import "@/styles/vedana/extra-tokens.css";

import InternalLayout from "@/layouts/InternalLayout.astro";
import { SEOBase } from "@content/vedana/seo/seo";
import type { SEOConfig } from "@/lib/seo/types";

import Callout from "@/components/blocks/callout/Callout.astro";

import EntityCardList from "@/components/blocks/entity-card/EntityCardList.astro";
import EntityCard from "@/components/blocks/entity-card/EntityCard.astro";
import EntityCardRichList from "@/components/blocks/entity-card/EntityCardRichList.astro";
import EntityCardRich from "@/components/blocks/entity-card/EntityCardRich.astro";

import Timeline from "@/components/blocks/timeline/Timeline.astro";
import TimelineItem from "@/components/blocks/timeline/TimelineItem.astro";

import Chat from "@/components/blocks/chat/Chat.astro";
import ChatItem from "@/components/blocks/chat/ChatItem.astro";

const bot = {
  name: "Vedana AI assistant",
  bubbleBg: "#eef3ff"
};

const user = {
  name: "User",
  bubbleBg: "#2A5BFF",
  bubbleColor: "#fff"
};


const crumbs = [
  { label: "Industries", href: "/industries" },
  { label: "Horeca" }
];

const pageSEO: Partial<SEOConfig> = {
  title: "Vedana for Horeca",
  description:
    "Structured AI platform for restaurants and hospitality.",
  canonical: "https://vedana.tech/industries/horeca",
  og: {
    type: "website",
    image: "https://vedana.tech/og-horeca.png",
    imageAlt: "Vedana for Horeca"
  }
};
---

<InternalLayout
  baseSEO={SEOBase}
  pageSEO={pageSEO}
  crumbs={crumbs}
>

    <section class="page-hero">
        <div class="page-hero-inner">
            <h1 class="page-hero-title">
                HoReCa runs on expertise.<br />
                But <strong>expertise is hard to scale</strong>.
            </h1>

          <p class="page-hero-lead">
                Vedana is an open-core AI platform, that encodes your operations logic, certifications, supplier data, service standards into a <strong>structured knowledge graph</strong> — so AI answers are verified. That scales expertise across teams, services, and regions.
          </p>
        </div>
    </section>

    <section class="section">
        <div class="container flow">
        <h2>
            Vedana saves your team expertise in <strong>AI-ready knowledge graph</strong>
        </h2>
            <Callout style="--callout-bg: hsl(75 30% 94%);">
                <h3>
                    Pre-modeled HoReCa ontology – ready to extend
                </h3>
                <p></p>
                <p>
                    VEDANA comes with a rich understanding of the HoReCa domain: brands, menu items, recipes, ingredients, equipment, supplies, beverages, certifications, service protocols and others.
                </p>
                <p>
                    We extend this model with your internal logic, formats, and documents, so your assistant answers questions in your language – not just industry standards.
                </p>
            </Callout>
<h3>
    Any Domain = <strong>Anchors, Attributes, Links</strong>
</h3>
<p>
    Vedana represents any business domain as a structured graph of <strong>anchors (entities), their attributes (properties), and explicit links (relationships)</strong>. <br/>
    In this HoReCa mini-demo, dishes, ingredients, suppliers, and certifications are typed nodes connected by governed business logic. 
    <br/>
    <strong>This is the foundation of our methodology: structured modeling first, AI reasoning on top.</strong>
</p>

<EntityCardRichList columns={3}>

  <EntityCardRich
    title="Brand"
    entityType="brand"
    color="var(--entity-brand)"
    attributes={[
      { key: "name", value: "Nordic Harbor" },
      { key: "concept type", value: "Casual seafood restaurant" },
      { key: "opening year", value: "2014" },
      { key: "website", value: "nordic-harbor.de", href: "https://nordic-harbor.de", external: true }
    ]}
    relations={[
      {
        label: "Holds",
        targets: [
          { title: "certificate: HACCP Certification 2023–2026", entityType: "certification", color: "var(--entity-compliance)" }
        ]
      }
    ]}
  />

  <EntityCardRich
    title="Dish"
    entityType="dish"
    color="var(--entity-dish)"
    attributes={[
      { key: "name", value: "Grilled Atlantic Salmon" },
      { key: "category", value: "Main course" },
      { key: "preparation time", value: "18 min" },
      { key: "serving size", value: "320 g" }
    ]}
    relations={[
      {
        label: "Contains",
        targets: [
          { title: "ingredient: Atlantic Salmon", entityType: "ingredient", color: "var(--entity-ingredient)" }
        ]
      }
    ]}
  />

  <EntityCardRich
    title="Ingredient"
    entityType="ingredient"
    color="var(--entity-ingredient)"
    attributes={[
      { key: "name", value: "Atlantic Salmon" },
      { key: "category", value: "Fish" },
      { key: "is allergen", value: "Yes" },
      { key: "shelf life", value: "3 days" },
      { key: "storage", value: "2-4°C refrigerated" },
      { key: "cost", value: "€8.40 / kg" }
    ]}
    relations={[
      {
        label: "Supplied by",
        targets: [
          { title: "supplier: NordSea Imports GmbH", entityType: "supplier", color: "var(--entity-supplier)" }
        ]
      }
    ]}
  />

  <EntityCardRich
    title="Wine"
    entityType="wine"
    color="var(--entity-wine)"
    attributes={[
      { key: "name", value: "Pinot Noir – Domaine Lefèvre" },
      { key: "type", value: "Red wine" },
      { key: "origin", value: "Burgundy, France" },
      { key: "serving temperature", value: "16–18°C" },
      { key: "body", value: "Medium" },
      { key: "acidity", value: "High" }
    ]}
    relations={[
      {
        label: "Complements",
        targets: [
          { title: "ingredient: Atlantic Salmon", entityType: "ingredient", color: "var(--entity-ingredient)" }
        ]
      }
    ]}
  />

  <EntityCardRich
    title="Certification"
    entityType="certification"
    color="var(--entity-compliance)"
    attributes={[
      { key: "name", value: "HACCP Certification 2023–2026" },
      { key: "standard number", value: "HACCP-DE-2023-4581" },
      { key: "scope", value: "Kitchen & cold storage operations" },
      { key: "issuing body", value: "German Food Safety Authority" },
      { key: "valid until", value: "Dec 2026" }
    ]}
  />

<EntityCardRich
  title="Supplier"
  entityType="supplier"
  color="var(--entity-supplier)"
  attributes={[
    { key: "name", value: "NordSea Imports GmbH" },
    { key: "company type", value: "Seafood distributor" },
    { key: "headquarters", value: "Hamburg, Germany" },
    { key: "certified for", value: "EU food import compliance" },
    { key: "delivery model", value: "Refrigerated daily supply" },
  ]}
  relations={[
    {
      label: "Supplies",
      targets: [
        { title: "ingredient: Atlantic Salmon", entityType: "ingredient", color: "var(--entity-ingredient)" }
      ]
    }
  ]}
/>

</EntityCardRichList>

        </div>
    </section>

    <section class="section">
        <div class="container flow">
        <h2>
            VEDANA makes all your knowledge accessible.
        </h2>
        <h3>
            From PDF to service answer – instantly.
        </h3>

            <Callout style="--callout-bg: var(--color-neutral-soft);">
                <h4>
                    👨‍🍳 Hospitality professional asks:
                </h4>
                <p></p>
                <p>
                    What wines pair well with a seared duck breast with cherry reduction that meet organic certification standards?
                </p>
            </Callout>
            
            <h3>How Vedana turns documents into answers:</h3>
            <div class="row">

                <Timeline orientation="vertical" lines={false}>
                        <TimelineItem index="1" title="Extraction">
                        <p>
                        Pull data from messy manuals, PDFs, Excels, and specs
                        </p>
                        </TimelineItem> 
                        <TimelineItem index="2" title="Normalization">
                        <p>
                        Clear and unify structure across formats
                        </p>
                        </TimelineItem> 
                        <TimelineItem index="3" title="Knowledge Graph">
                        <p>
                        Build connections between entities
                        </p>
                        </TimelineItem> 
                        <TimelineItem index="4" title="Knowledge Graph Search">
                        <p>
                        Search by meaning, not just keywords
                        </p>
                        </TimelineItem> 
                </Timeline>   
                
                <Chat
                    title="Chat with Vedana"
                    showDate={false}
                    dateLabel="Monday, June 9, 2025"
                    reactions={[
                    ]}
                    >

                    <ChatItem
                        participant={2}
                        text="What wines pair well with a seared duck breast with cherry reduction that meet organic certification standards?"
                        participant1={bot}
                        participant2={user}
                    />

                    <ChatItem
                    participant={1}
                    participant1={bot}
                    participant2={user}
                        >
                        <p><strong>Understood:</strong></p>

                        <ul>
                            <li><code>organic certification standards</code> standard</li>
                            <li><code>seared duck breast with cherry reduction</code> dish type</li>
                            <li><code>pair_well_with</code> - relation between wine and dish</li>
                        </ul>

                        <p>Querying graph...</p>
                    </ChatItem>

                    <ChatItem
                    participant={1}
                    participant1={bot}
                    participant2={user}
                        >
                        <p><strong>Answer:</strong></p>

                        <ul>
                            <li><strong>Pinot Noir from Burgundy</strong></li>
                            <li><strong>Syrah from Rhône Valley</strong></li>
                        </ul>

                        <p>
                            All meet the Restaurant Association's sustainable sourcing guidelines for organic wines.
                        </p>
                    </ChatItem>

                    </Chat>

            </div>    
        </div>
    </section>

    <section class="section">
        <div class="container flow">
        <h2>
            <strong>Vedana</strong> reasons like a hospitality professional – with rules, steps, and structure 
        </h2>
        <p></p>
        <Timeline orientation="horizontal" lines={true}>
            <TimelineItem index="1" title="Playbook defines the logic">
                        <p>
                        A service-specific playbook guides Vedana how to think:<br/>
                        
                        “If query includes certification + menu item + ingredient → look for menu compatibility across all three entities.”
                        <br />
                        Logic is visible and customizable.
                        </p>
                        </TimelineItem> 
                        <TimelineItem index="2" title="Domain graph defines the structure">
                        <p>
                        Vedana explores your knowledge graph:Menu Item → Recipe → Ingredient → Health & Safety Standardto trace dependencies and rules across layers.
                        </p>
                        </TimelineItem> 
                        <TimelineItem index="3" title="Data model feeds the answer">
                        <p>
                        Each answer is supported by your data: service specifications, health & safety regulations, menu compatibility logic — not hallucination.Feedback from users is logged and used to improve the Playbook.
                        </p>
                </Timeline>  
        </div>
    </section>
    



    <section class="section">
        <div class="container flow">
        <h2>
            Page header H2-3
        </h1>

        <p>
            Simple page text.
        </p>
        </div>
    </section>


</InternalLayout>