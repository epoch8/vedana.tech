---
import { extendSEO } from "@/lib/seo/extend";
import type { SEOConfig } from "@/lib/seo/types";

interface Props {
  baseSEO: SEOConfig;
  pageSEO?: Partial<SEOConfig>;
  structuredData?: object | object[];
  lang?: string;
}

const {
  baseSEO,
  pageSEO,
  structuredData,
  lang = "en",
} = Astro.props;

// Deterministic merge
const seo: SEOConfig = pageSEO
  ? extendSEO(baseSEO, pageSEO)
  : baseSEO;

const {
  title,
  description,
  canonical,
  noindex,
  og,
  twitter,
} = seo;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    {noindex && <meta name="robots" content="noindex,nofollow" />}

    {canonical && <link rel="canonical" href={canonical} />}

    {/* Open Graph */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={og?.type ?? "website"} />
    {canonical && <meta property="og:url" content={canonical} />}
    {og?.image && <meta property="og:image" content={og.image} />}
    {og?.imageAlt && (
      <meta property="og:image:alt" content={og.imageAlt} />
    )}

    {/* Twitter */}
    <meta
      name="twitter:card"
      content={twitter?.card ?? "summary_large_image"}
    />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {(twitter?.image ?? og?.image) && (
      <meta
        name="twitter:image"
        content={twitter?.image ?? og?.image}
      />
    )}

    {/* Structured Data */}
    {structuredData &&
      (Array.isArray(structuredData)
        ? structuredData.map((item) => (
            <script type="application/ld+json">
              {JSON.stringify(item)}
            </script>
          ))
        : (
            <script type="application/ld+json">
              {JSON.stringify(structuredData)}
            </script>
          ))}

    {/* Extra head injection */}
    <slot name="head" />
  </head>

  <body>
    <slot />
  </body>
</html>