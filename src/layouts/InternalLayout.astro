---
import BaseLayout from "@/layouts/baseLayout.astro";
import GraphBreadcrumb from "@/components/blocks/graph-elements/GraphBreadcrumb.astro";

import styles from "./InternalLayout.module.css";
import "../styles/global.css";


import type { SEOConfig } from "@/lib/seo/types";

type Crumb = {
  label: string;
  href?: string;
  nodeId?: string;
};

interface Props {
  baseSEO: SEOConfig;
  pageSEO?: Partial<SEOConfig>;
  structuredData?: object | object[];

  crumbs: Crumb[];

  class?: string;
}

const {
  baseSEO,
  pageSEO,
  structuredData,
  crumbs = [],
  class: extraClass = ""
} = Astro.props;

const baseUrl = import.meta.env.PUBLIC_SITE_URL;
---

<BaseLayout
  baseSEO={baseSEO}
  pageSEO={pageSEO}
  structuredData={structuredData}
>

  <div class={styles["header-spine-gap"]} aria-hidden="true"></div>

  <div class={`${styles["internal-layout"]} ${extraClass}`}>
    
    <aside class={styles["spine"]}>
      <GraphBreadcrumb
        crumbs={crumbs}
        baseUrl={baseUrl}
        schema={true}
      />
    </aside>

    <main class={styles["content"]}>
      <slot />
    </main>

  </div>
</BaseLayout>