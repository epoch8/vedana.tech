---
/*
  ReasoningTraceDiagram
  Vedana shows how AI reasons over structured knowledge
*/
---

<div class="reasoning-diagram">

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="45 90 1280 320"
  fill="none"
  role="img"
  aria-label="AI reasoning over Vedana structured knowledge"
>

  <defs>

    <filter id="shadowSoft" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow
        dx="0"
        dy="10"
        stdDeviation="14"
        flood-color="#0F172A"
        flood-opacity="0.08"
      />
    </filter>

    <filter id="shadowCard" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow
        dx="0"
        dy="6"
        stdDeviation="10"
        flood-color="#0F172A"
        flood-opacity="0.06"
      />
    </filter>

  </defs>


  <g id="connectors">

<path class="line" d="M420 240 H520"></path>
<circle cx="520" cy="240" r="5" fill="#9CA3AF"></circle>

<path class="line" d="M880 240 H980"></path>
<circle cx="880" cy="240" r="5" fill="#9CA3AF"></circle>

</g>


<!-- LEFT COLUMN : USER QUERY -->

<g filter="url(#shadowCard)">
<rect x="60" y="160" width="360" height="170" rx="26" fill="#FFFFFF" stroke="#D9E0EA" stroke-width="2"></rect>
</g>

<text x="90" y="200" class="title">User query</text>

<text x="90" y="245" class="query">
Which suppliers provide
</text>

<text x="90" y="275" class="query">
certified batteries
</text>

<text x="90" y="305" class="query">
for the EU market?
</text>



<!-- CENTER : AI REASONING -->

<g filter="url(#shadowSoft)">
<rect x="520" y="110" width="360" height="260" rx="30" fill="#EEF4FF" stroke="#C7D7F3" stroke-width="2"></rect>
</g>

<text x="700" y="150" text-anchor="middle" class="title">
AI reasoning
</text>


<!-- STEP 1 -->

<g filter="url(#shadowCard)">
<rect x="560" y="170" width="280" height="48" rx="18" fill="#FFFFFF" stroke="#D9E0EA" stroke-width="2"></rect>
</g>

<!-- entity color -->
<circle cx="584" cy="194" r="9" fill="#DDEAFE" stroke="#6A99F0" stroke-width="2"></circle>

<text x="606" y="200" class="step">
1. Query Product entities
</text>


<!-- STEP 2 -->

<g filter="url(#shadowCard)">
<rect x="560" y="228" width="280" height="48" rx="18" fill="#FFFFFF" stroke="#D9E0EA" stroke-width="2"></rect>
</g>

<circle cx="584" cy="252" r="9" fill="#F9E1EE" stroke="#EC6FB1" stroke-width="2"></circle>

<text x="606" y="258" class="step">
2. Filter EU certificates
</text>


<!-- STEP 3 -->

<g filter="url(#shadowCard)">
<rect x="560" y="286" width="280" height="48" rx="18" fill="#FFFFFF" stroke="#D9E0EA" stroke-width="2"></rect>
</g>

<circle cx="584" cy="310" r="9" fill="#DDF4E6" stroke="#59C97E" stroke-width="2"></circle>

<text x="606" y="316" class="step">
3. Match suppliers
</text>



<!-- RIGHT COLUMN : ANSWER -->

<g filter="url(#shadowCard)">
<rect x="980" y="150" width="300" height="200" rx="26" fill="#FFFFFF" stroke="#D9E0EA" stroke-width="2"></rect>
</g>

<text x="1010" y="190" class="title">
Structured answer
</text>

<text x="1010" y="235" class="answer">
3 compliant suppliers
</text>

<text x="1010" y="275" class="supplier">
ACME Power Ltd
</text>

<text x="1010" y="300" class="supplier">
EuroBattery GmbH
</text>

<text x="1010" y="325" class="supplier">
GreenVolt
</text>

</svg>

</div>


<style>

.reasoning-diagram{
  width:100%;
  max-width:1200px;
  margin:0 auto;
}

.reasoning-diagram svg{
  width:100%;
  height:auto;
  display:block;
}


/* =========================
   TYPOGRAPHY
========================= */

.reasoning-diagram .title{
  font-family:Inter, system-ui, sans-serif;
  font-size:16px;
  font-weight:700;
  letter-spacing:.08em;
  text-transform:uppercase;
  fill:#94A3B8;
}

.reasoning-diagram .query{
  font-family:Inter, system-ui, sans-serif;
  font-size:22px;
  font-weight:600;
  fill:#0F172A;
}

.reasoning-diagram .step{
  font-family:Inter, system-ui, sans-serif;
  font-size:17px;
  font-weight:600;
  fill:#334155;
}

.reasoning-diagram .answer{
  font-family:Inter, system-ui, sans-serif;
  font-size:20px;
  font-weight:700;
  fill:#0F172A;
}

.reasoning-diagram .supplier{
  font-family:Inter, system-ui, sans-serif;
  font-size:18px;
  font-weight:600;
  fill:#334155;
}


/* =========================
   LINES
========================= */

.reasoning-diagram .line{
  stroke:#9CA3AF;
  stroke-width:3;
  stroke-linecap:round;
}

</style>