---
import BaseLayout from "@/layouts/baseLayout.astro";
import DocsSidebar from "@/components/products/vedana/DocsSidebar.astro";
import Footer from "@/components/products/vedana/footer/Footer.astro";

import styles from "./DocsLayout.module.css";
import "../styles/global.css";

import type { SEOConfig } from "@/lib/seo/types";
import type { CollectionEntry } from "astro:content";

type Doc = CollectionEntry<"docs">;

interface Props {
  baseSEO?: SEOConfig;
  pageSEO?: Partial<SEOConfig>;
  structuredData?: object | object[];

  currentSlug?: string; // ← фикс (не ломаемся на index)
  headings?: any;

  allDocs: Doc[];

  title?: string;
  description?: string;
}

const {
  baseSEO,
  pageSEO,
  structuredData,

  currentSlug,
  headings,
  allDocs,

  title,
  description,
} = Astro.props;

/* ======================================================
   SEO BASE
====================================================== */

const safeBaseSEO: SEOConfig = baseSEO ?? {
  title: "Vedana Docs",
  description:
    "Documentation for Vedana — graph-first AI for enterprise decisions.",
  canonical: "https://vedana.tech/docs",

  og: {
    type: "website",
    image: "/og/vedana-docs.png",
    imageAlt: "Vedana Docs",
  },

  twitter: {
    card: "summary_large_image",
    image: "/og/vedana-docs.png",
  },
};

/* ======================================================
   PAGE SEO
====================================================== */

const safePageSEO: Partial<SEOConfig> = {
  ...(pageSEO ?? {}),
  ...(title && { title }),
  ...(description && { description }),
};
---

<BaseLayout
  baseSEO={safeBaseSEO}
  pageSEO={safePageSEO}
  structuredData={structuredData}
>
  <div class="page-root">

    <div class={styles.container}>
      
      <aside class={styles.sidebar}>
        <DocsSidebar
          allDocs={allDocs}
          currentSlug={currentSlug ?? ""}  
        />
      </aside>

      <main class={styles.content}>
        <slot />
      </main>

    </div>

    <Footer />

  </div>
</BaseLayout>