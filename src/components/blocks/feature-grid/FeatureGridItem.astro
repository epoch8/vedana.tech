---
import styles from "./FeatureGrid.module.css";

interface Props {
  title?: string;
  image?: string;
  imageAlt?: string;
  text?: string;
  position?: number;
}

const { title, image, imageAlt = "", text, position } = Astro.props;
---

<div
  class={styles["feature-grid__item"]}
  itemscope
  itemprop="itemListElement"
  itemtype="https://schema.org/ListItem"
>
  {position && (
    <meta itemprop="position" content={String(position)} />
  )}

  {title && (
    <h3
      class={styles["feature-grid__title"]}
      itemprop="name"
    >
      {title}
    </h3>
  )}

  {image && (
    <div class={styles["feature-grid__image-wrapper"]}>
      <img
        src={image}
        alt={imageAlt}
        class={styles["feature-grid__image"]}
        itemprop="image"
      />
    </div>
  )}

  {text && (
    <div
      class={styles["feature-grid__text"]}
      itemprop="description"
      set:html={text}
    />
  )}
</div>