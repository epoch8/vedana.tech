---
import styles from "./Table.module.css"

const { table } = Astro.props
const { columns, rows } = table
---

<div class={styles.table}>

  <div class={styles.header}>

    {columns.map(col => (
      <div class={styles.headerCell}>

        {col.title}

        {col.badge && (
          <span class={`${styles.badge} ${col.variant === "semantic" ? styles.badgePrimary : ""}`}>
            {col.badge}
          </span>
        )}

      </div>
    ))}

  </div>

  <div class={styles.body}>

    {rows.map(row => (

      <div class={styles.row}>

        {columns.map(col => {

          const cell = row[col.key]

          return (

            <div class={styles.cell}>

              {cell?.icon && (
                <span
                  class={`${styles.icon} ${
                    cell.icon === "good"
                      ? styles.iconGood
                      : styles.iconBad
                  }`}
                >
                  {cell.icon === "good" ? "✓" : "✕"}
                </span>
              )}

              <div>

                {cell?.title && (
                  <div class={styles.cellTitle}>
                    {cell.title}
                  </div>
                )}

                {cell?.example && (
                  <div class={styles.cellExample}>
                    {cell.example}
                  </div>
                )}

                {cell?.text && (
                  <div class={styles.text}>
                    {cell.text}
                  </div>
                )}

                {cell?.html && (
                  <div
                    class={styles.text}
                    set:html={cell.html}
                  />
                )}

              </div>

            </div>

          )

        })}

      </div>

    ))}

  </div>

</div>