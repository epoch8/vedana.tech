---
import Anchor from "./Anchor.astro";
import styles from "./GraphBreadcrumb.module.css";

type Crumb = {
  label: string;
  href?: string;
};

interface Props {
  crumbs: Crumb[];
  baseUrl?: string;
  schema?: boolean;
}

const {
  crumbs = [],
  baseUrl,
  schema = true
} = Astro.props;

const lastIndex = crumbs.length - 1;

function isCurrent(i: number, c: Crumb) {
  return !c.href || i === lastIndex;
}
---

<nav class={styles["spine-nav"]} aria-label="Breadcrumb">
  {crumbs.map((c, i) => {
    const current = isCurrent(i, c);
    const href = current ? undefined : c.href;

    return (
      <Fragment>

        {/* Desktop graph node */}
        <Anchor
          href={href}
          size="lg"
          variant="circle"
          class={`
            ${styles["spine-anchor"]}
            ${styles["desktop-only"]}
            ${current ? styles["spine-anchor--current"] : ""}
          `}
        >
          {c.label}
        </Anchor>

        {/* Mobile inline breadcrumb */}
        <Anchor
          href={href}
          variant="inline"
          class={styles["mobile-only"]}
        >
          {c.label}
        </Anchor>

      </Fragment>
    );
  })}
</nav>