---
import BaseLayout from "@/layouts/baseLayout.astro";

import { SEOBase } from "@content/vedana/seo/seo";

import SiteHeader from "@/components/products/vedana/header/Nav.astro";
import Hero from "@/components/products/vedana/Hero.astro";
import Problem from "@/components/products/vedana/Problem.astro";
import MiniDemo from "@/components/products/vedana/MiniDemo.jsx";
import Methodology from "@/components/products/vedana/Methodology.astro";
import CTA from "@/components/products/vedana/CTA.astro";
import Footer from "@/components/products/vedana/footer/Footer.astro";
import ScrollFrames from "@/components/products/vedana/scroll-frame/ScrollFrames.js";

import FAQ from "@/components/blocks/faq/FAQ.astro";
import { vedanaFaq } from "@content/vedana/faq";


import "../styles/global.css";
---

<BaseLayout
  baseSEO={SEOBase}
  pageSEO={{
    title: "Vedana — Deterministic Graph-First AI",
    description:
      "Vedana builds structured knowledge graphs so AI answers follow business rules, not similarity guesses.",
    canonical: "https://vedana.tech/",
  }}
>
  <div class="page-root">
    <SiteHeader client:load />

    <Hero />

    <ScrollFrames client:load />

    <Problem />

    <MiniDemo client:visible />

    <Methodology />

    <FAQ title="FAQ" items={vedanaFaq} />

    <CTA />

    <Footer />
  </div>
</BaseLayout>