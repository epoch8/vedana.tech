---
import styles from "./Nav.module.css";
import BrandLogo from "../../products/vedana/logo/BrandLogo.astro";

/* ================================
   Types
================================ */

export type NavItemKind = "cta";

export interface NavItem {
  label: string;
  href: string;
  kind?: NavItemKind;
}

interface Props {
  items: NavItem[];
  siteUrl?: string;
}

const { items = [], siteUrl = "" } = Astro.props;

/* ================================
   Structured Data
================================ */

const navigationSchema = {
  "@context": "https://schema.org",
  "@type": "SiteNavigationElement",
  name: items.map((item) => item.label),
  url: items.map((item) =>
    siteUrl && item.href.startsWith("/")
      ? `${siteUrl}${item.href}`
      : item.href
  ),
};
---

<header
  id="site-header"
  class={styles["nav-header"]}
  data-open="false"
>
  <div class={styles["nav-inner"]}>
    <BrandLogo href="/#home" />

    <nav
      id="primary-nav"
      class={styles["nav-links"]}
      aria-label="Primary"
      itemscope
      itemtype="https://schema.org/SiteNavigationElement"
    >
      {items.map((item) => (
        <a
          href={item.href}
          class={
            item.kind === "cta"
              ? `${styles["nav-link"]} ${styles["nav-cta"]}`
              : styles["nav-link"]
          }
          itemprop="url"
        >
          <span itemprop="name">{item.label}</span>
        </a>
      ))}
    </nav>

    <button
      id="menu-toggle"
      class={styles["nav-menu-toggle"]}
      aria-label="Toggle menu"
      aria-controls="primary-nav"
      aria-expanded="false"
      type="button"
    >
      ☰
    </button>
  </div>
</header>

<div
  id="nav-overlay"
  class={styles["nav-overlay"]}
></div>

<script type="application/ld+json">
  {JSON.stringify(navigationSchema)}
</script>

<script type="module" src="/scripts/nav.js"></script>