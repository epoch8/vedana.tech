---
import ProblemTable from './ProblemTable.jsx';
---

<section id="problem" class="problem-section">
  <div class="problem-inner">
    <div class="problem-badge">Problem</div>
    <h2>Why classic RAG isn't enough</h2>

    <div class="problem-table-wrap">
      <ProblemTable client:visible />
    </div>

    <div class="problem-link">
      <a href="#demo">See how Vedana fixes this →</a>
    </div>
  </div>
</section>

<style>
.problem-section {
  padding: 5rem 0;
  background: #fff;
}
.problem-inner {
  max-width: 80rem;
  margin: 0 auto;
  padding: 0 1rem;
}
.problem-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  border-radius: 9999px;
  border: 1px solid #e2e8f0;
  background: #fff;
  padding: 0.25rem 0.75rem;
  font-size: 1.125rem;
  color: #475569;
  box-shadow: 0 1px 2px rgba(0,0,0,0.05);
}
h2 {
  margin: 1rem 0 0;
  font-size: 1.875rem;
  font-weight: 700;
  color: #0f172a;
}
@media (min-width: 768px) {
  h2 { font-size: 2.25rem; }
}
.problem-table-wrap {
  margin-top: 1.5rem;
  overflow-x: auto;
}
.problem-link {
  margin-top: 1.5rem;
  font-size: 0.875rem;
}
.problem-link a {
  color: #2563eb;
  text-decoration: none;
}
.problem-link a:hover {
  text-decoration: underline;
}
</style>
