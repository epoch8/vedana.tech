---
import "./timeline.css";

interface Props {
  orientation?: "horizontal" | "vertical";
  side?: "one-sided" | "two-sided";
  lines?: boolean;
}

const {
  orientation = "horizontal",
  side = "two-sided",
  lines = true,
} = Astro.props;

const classes = [
  "timeline",
  `timeline--${orientation}`,
  `timeline--${side}`,
  lines ? "timeline--with-lines" : "timeline--no-lines",
].join(" ");
---

<ol
  class={classes}
  itemscope
  itemtype="https://schema.org/HowTo"
>
  <slot />
</ol>