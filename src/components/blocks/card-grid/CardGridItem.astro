---
import styles from "./CardGrid.module.css";

interface Props {
  title?: string;
  image?: string;
  imageAlt?: string;
  text?: string;
  href?: string;
  buttonLabel?: string;
  position?: number;

  span?: 1 | 2 | 3;
  rowSpan?: 1 | 2;

  background?: string;
  borderColor?: string;
}

const {
  title,
  image,
  imageAlt = "",
  text,
  href,
  buttonLabel = "Learn more",
  position,

  span,
  rowSpan,
  background,
  borderColor
} = Astro.props as Props;

const isLink = Boolean(href);
const Tag = isLink ? "a" : "div";

/* ------------------------------------
   GRID SPAN CLASSES
------------------------------------ */

const spanClass =
  span === 2
    ? styles["card--span-2"]
    : span === 3
    ? styles["card--span-3"]
    : "";

const rowSpanClass =
  rowSpan === 2
    ? styles["card--row-2"]
    : "";

/* ------------------------------------
   STYLE VARIABLES
------------------------------------ */

const style = [
  background ? `--card-bg:${background}` : "",
  borderColor ? `--card-border:${borderColor}` : ""
].filter(Boolean).join(";");

/* ------------------------------------
   FINAL CLASS
------------------------------------ */

const className = [
  styles["card"],
  spanClass,
  rowSpanClass
].filter(Boolean).join(" ");
---

<Tag
  {...(isLink ? { href } : {})}
  class={className}
  style={style}
  itemscope
  itemprop="itemListElement"
  itemtype="https://schema.org/ListItem"
>

  {position && (
    <meta itemprop="position" content={String(position)} />
  )}

  <div class={styles["card__body"]}>

    {title && (
      <h3 class={styles["card__title"]} itemprop="name">
        {title}
      </h3>
    )}

    {image && (
      <div class={styles["card__media"]}>
        <img
          src={image}
          alt={imageAlt}
          class={styles["card__image"]}
          itemprop="image"
        />
      </div>
    )}

    {text && (
      <div
        class={styles["card__text"]}
        itemprop="description"
        set:html={text}
      />
    )}

  </div>

  {isLink && (
    <div class={styles["card__footer"]}>
      <span class="btn-secondary">
        {buttonLabel}
      </span>
    </div>
  )}

</Tag>